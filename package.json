{
  "author": "eniallator",
  "description": "My personal website's source code",
  "homepage": "https://cdrn.cc/",
  "license": "MIT",
  "name": "personal-website",
  "packageManager": "bun@1.3.5",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.8.0"
  },
  "scripts": {
    "build:ts": "bun esbuild.mjs",
    "build:css": "bun cssbuild.mjs",
    "build": "bun run build:ts && bun run build:css",
    "start": "bun dist/index.js",
    "lint": "eslint ./server ./client",
    "typecheck": "tsc --noEmit",
    "findissues": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "deep-guards": "^1.4.0",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "niall-utils": "^1.4.0",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "5.0.6",
    "@types/node": "26.0.0",
    "@types/nodemailer": "^8.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eniallator/Personal-Website.git"
  },
  "bugs": {
    "url": "https://github.com/eniallator/Personal-Website/issues"
  }
}
